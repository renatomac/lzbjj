@members_bp.route('/add_promotion', methods=['POST'])
@login_required
def add_promotion():
    """
    Adds a belt promotion for a member based on BeltPromotionForm.
    - Updates the member's belt_rank to the new rank.
    - Records a BeltPromotion entry with old/new ranks and date.
    """
    form = BeltPromotionForm()
    if form.validate_on_submit():
        member_id = form.member.data  # BeltPromotionForm.member is SelectField(coerce=int)
        member = Member.query.get_or_404(member_id)

        promotion = BeltPromotion(
            member_id=member.id,
            old_rank=member.belt_rank or 'unknown',
            new_rank=form.new_belt_rank.data,
            promotion_date=form.promotion_date.data,
            notes=form.notes.data,
            # Optionally set promoted_by_id if you have current staff context
        )
        try:
            with db.session.begin():
                db.session.add(promotion)
                # Update the member's belt rank and optionally reset stripes
                member.belt_rank = promotion.new_rank
                member.stripes = 0
                db.session.add(member)
        except SQLAlchemyError:
            db.session.rollback()
            current_app.logger.exception('SQLAlchemyError while adding promotion for member %s', member_id)
            flash('An error occurred while adding the promotion.', 'danger')
        else:
            flash('Promotion added successfully.', 'success')
            return redirect(url_for('members.view', member_id=member.id))

    # On initial GET this route isn't used; if used as a fallback on invalid POST:
    return render_template('members/add_promotion.html', title='Add Promotion', form=form)


@members_bp.route('/toggle_status/<int:member_id>', methods=['POST'])
@login_required
def toggle_status(member_id):
    """
    Toggles the active status of a member.
    """
    member = Member.query.get_or_404(member_id)
    member.is_active = not member.is_active
    try:
        with db.session.begin():
            db.session.add(member)
    except SQLAlchemyError:
        db.session.rollback()
        current_app.logger.exception('SQLAlchemyError while toggling status for member %s', member_id)
        flash('An error occurred while updating member status.', 'danger')
    else:
        flash('Member status updated successfully.', 'success')
    return redirect(url_for('members.view', member_id=member.id))